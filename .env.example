# Mailchimp (optional — форма работает и без ключей, лиды пишутся в лог)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=us1

# Gemini (AI-приложения: ColdMessage, ObjectionKiller, LeadRadar)
GEMINI_API_KEY=

# Upstash Redis (дневной rate limit 30/день на все API; без него — in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
